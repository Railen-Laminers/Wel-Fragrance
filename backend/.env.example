# Wel Fragrance Backend - Environment Configuration Example
# Copy this file to .env and fill in your actual values
# Never commit .env file to version control!

# ============================================================================
# Database Configuration
# ============================================================================
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/wel-fragrance?retryWrites=true&w=majority

# ============================================================================
# Server Configuration
# ============================================================================
PORT=5000

# ============================================================================
# Authentication (Admin Setup)
# ============================================================================
ADMIN_EMAIL=admin@welfragrance.com
ADMIN_PASSWORD=YourSecurePassword123!

# ============================================================================
# SMTP Email Configuration
# ============================================================================

# Gmail Setup (Recommended for Development)
# 1. Go to: https://myaccount.google.com/apppasswords
# 2. Select Mail → Windows Computer
# 3. Copy the 16-character password and use below

# Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Alternative: Outlook
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USERNAME=your-email@outlook.com
# SMTP_PASSWORD=your-outlook-password

# Alternative: SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=SG.your-sendgrid-api-key

# Alternative: Custom SMTP Server
# SMTP_HOST=your-smtp-server.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USERNAME=your-username
# SMTP_PASSWORD=your-password

# Sender Email Configuration
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Wel Fragrance

# ============================================================================
# Admin Dashboard Configuration
# ============================================================================
# URL of your admin dashboard (used in email links)
ADMIN_DASHBOARD_URL=http://localhost:3000

# Admin email for notifications (can be same as ADMIN_EMAIL or different)
# This email receives inquiry and testimonial notifications
ADMIN_EMAIL=admin@welfragrance.com

# ============================================================================
# Notes & Tips
# ============================================================================
# 
# Gmail Users:
# - Must use an app-specific password, NOT your Gmail password
# - Must have 2-Step Verification enabled
# - Get app password at: https://myaccount.google.com/apppasswords
# - Remove spaces from the 16-character password
#
# Production Deployment:
# - Use a dedicated email service (SendGrid, Mailgun, AWS SES)
# - Update ADMIN_DASHBOARD_URL to your production domain
# - Configure SPF, DKIM, and DMARC DNS records
# - Use strong, randomly-generated passwords
#
# Security:
# - Never commit this file to version control
# - Add .env to .gitignore
# - Rotate credentials periodically
# - Use environment variables from hosting provider
# - Keep this file secure and backed up
#
# Email Verification:
# - All emails are sent asynchronously (non-blocking)
# - Emails arrive within 1-5 seconds typically
# - Check server console for "✅ Email sent successfully..." logs
# - If emails fail, check console for error messages
#
