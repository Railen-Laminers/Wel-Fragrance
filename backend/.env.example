# Wel Fragrance Backend - Environment Configuration Example
# Copy this file to .env and fill in your actual values.
# Use the same values for Railway deployment.

# Database
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/wel-fragrance?retryWrites=true&w=majority

# Server
PORT=5000

# Authentication
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@welfragrance.com
ADMIN_PASSWORD=replace-with-a-strong-password

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Wel Fragrance

# Frontend / Email links
FRONTEND_URL=https://your-frontend.vercel.app
BASE_URL=https://your-backend.railway.app
